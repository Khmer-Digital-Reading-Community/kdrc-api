              "raw": "http://localhost:3001/chapters/book/00000000-0000-0000-0000-000000000000",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["chapters", "book", "00000000-0000-0000-0000-000000000000"]
            }
          }
        },
